#!/bin/bash
set -euo pipefail

# =============================================================================
# baize-kube postinst
# Provisions the baize user, cgroup delegation, minikube, and systemd service.
# =============================================================================

BAIZE_USER="baize"
BAIZE_GROUP="baize"
ADMINS_GROUP="baize-admins"
CONSUMERS_GROUP="baize-consumers"
BAIZE_HOME="/home/${BAIZE_USER}"
ADMIN_KUBECONFIG="/etc/baize-kube/admin-kubeconfig"
CMDLINE_FILE="/boot/firmware/cmdline.txt"
DELEGATE_CONF="/etc/systemd/system/user@.service.d/delegate.conf"
MINIKUBE_BIN="/usr/local/bin/minikube"
KUBECTL_BIN="/usr/local/bin/kubectl"
MINIKUBE_SERVICE_DIR="${BAIZE_HOME}/.config/systemd/user"
MINIKUBE_SERVICE="${MINIKUBE_SERVICE_DIR}/minikube.service"
CONSUMERS_CONF="/etc/baize-kube/consumers.conf"
REBOOT_SERVICE_SRC="/usr/lib/baize-kube/baize-kube-reboot.service"
REBOOT_SERVICE_DST="/etc/systemd/system/baize-kube-reboot.service"
REBOOT_FLAG="/var/lib/baize-kube/needs-reboot"
REBOOT_FLAG_DIR="/var/lib/baize-kube"

ARCH="arm64"
MINIKUBE_VERSION="v1.38.1"
KUBECTL_VERSION="v1.31.0"  # Pinned for reproducibility; update with minikube version

# Expected SHA256 checksum for minikube binary (defense-in-depth per OWASP A08)
# Verify against https://github.com/kubernetes/minikube/releases/tag/${MINIKUBE_VERSION}
MINIKUBE_SHA256="a0b8a1ebfc8c07a247271d8df98ac0ddd7c8c855b601d402463e2e50c08c6bab"

# -----------------------------------------------------------------------------
# Helpers
# -----------------------------------------------------------------------------

info()    { echo "[baize-kube] INFO:  $*"; }
success() { echo "[baize-kube] OK:    $*"; }
warn()    { echo "[baize-kube] WARN:  $*"; }
fail()    { echo "[baize-kube] ERROR: $*" >&2; exit 1; }

require_root() {
    [ "$(id -u)" -eq 0 ] || fail "This script must be run as root."
}

# -----------------------------------------------------------------------------
# 1. Network connectivity check
# -----------------------------------------------------------------------------

check_network() {
    info "Checking network connectivity..."
    curl -fsSL --max-time 10 -o /dev/null https://dl.k8s.io/ \
        || fail "Cannot reach dl.k8s.io. Ensure internet access before installing."
    if ! curl -fsSL --max-time 5 -o /dev/null https://github.com > /dev/null 2>&1; then
        fail "Cannot reach github.com. Check network connectivity."
    fi
    success "Network connectivity confirmed."
}

# -----------------------------------------------------------------------------
# 2. cgroup v2 memory controller check and cmdline.txt patch
# -----------------------------------------------------------------------------

check_and_patch_cgroup() {
    info "Checking cgroup v2 memory controller..."

    CONTROLLERS=$(cat /sys/fs/cgroup/cgroup.controllers 2>/dev/null || echo "")

    if echo "$CONTROLLERS" | grep -qw "memory"; then
        info "cgroup memory controller already active — skipping cmdline.txt edit."
        return 0
    fi

    warn "cgroup memory controller is NOT active."
    info "Checking ${CMDLINE_FILE}..."

    [ -f "$CMDLINE_FILE" ] || fail "${CMDLINE_FILE} not found. Cannot enable memory cgroup."

    CMDLINE=$(cat "$CMDLINE_FILE")

    if echo "$CMDLINE" | grep -q "cgroup_enable=memory"; then
        info "cgroup_enable=memory already present in ${CMDLINE_FILE} — skipping edit."
    else
        info "Patching ${CMDLINE_FILE} to enable memory cgroup..."
        # Must remain a single line
        # Only create backup if it doesn't already exist
        [ -f "${CMDLINE_FILE}.bak-baize-kube" ] || cp "$CMDLINE_FILE" "${CMDLINE_FILE}.bak-baize-kube"
        echo "${CMDLINE} cgroup_memory=1 cgroup_enable=memory" > "$CMDLINE_FILE"
        success "Patched ${CMDLINE_FILE}."
    fi

    # Install post-reboot trigger: flag file + oneshot systemd service
    info "Installing post-reboot trigger..."

    mkdir -p "$REBOOT_FLAG_DIR"
    touch "$REBOOT_FLAG"

    cp "$REBOOT_SERVICE_SRC" "$REBOOT_SERVICE_DST"
    systemctl daemon-reload
    systemctl enable baize-kube-reboot.service

    success "Post-reboot trigger installed."

    echo ""
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║  REBOOT REQUIRED                                            ║"
    echo "║                                                             ║"
    echo "║  The kernel boot parameters have been updated to enable     ║"
    echo "║  the cgroup memory controller, which is required for        ║"
    echo "║  rootless Podman to enforce memory limits on containers.    ║"
    echo "║                                                             ║"
    echo "║  Please reboot now:                                         ║"
    echo "║    sudo reboot                                              ║"
    echo "║                                                             ║"
    echo "║  Installation will complete automatically on next boot.    ║"
    echo "║  No manual re-run of dpkg is required.                     ║"
    echo "╚══════════════════════════════════════════════════════════════╝"
    echo ""
    exit 1  # Non-zero exit so dpkg leaves package Half-Configured
}

# -----------------------------------------------------------------------------
# 3. systemd cgroup delegation for user sessions
# -----------------------------------------------------------------------------

configure_cgroup_delegation() {
    info "Configuring systemd cgroup delegation..."
    mkdir -p "$(dirname "$DELEGATE_CONF")"
    cat > "$DELEGATE_CONF" <<EOF
[Service]
Delegate=cpu cpuset io memory pids
EOF
    systemctl daemon-reload
    success "cgroup delegation configured at ${DELEGATE_CONF}."
}

# -----------------------------------------------------------------------------
# 4. Create baize user and baize-consumers group
# -----------------------------------------------------------------------------

provision_user() {
    info "Provisioning user and groups..."

    # baize-admins group for cluster administrators
    if ! getent group "$ADMINS_GROUP" > /dev/null 2>&1; then
        groupadd --system "$ADMINS_GROUP"
        success "Group '${ADMINS_GROUP}' created."
    else
        info "Group '${ADMINS_GROUP}' already exists."
    fi

    # baize-consumers group for human users to be provisioned
    if ! getent group "$CONSUMERS_GROUP" > /dev/null 2>&1; then
        groupadd --system "$CONSUMERS_GROUP"
        success "Group '${CONSUMERS_GROUP}' created."
    else
        info "Group '${CONSUMERS_GROUP}' already exists."
    fi

    # baize user: regular user (not system) so it gets subuid/subgid ranges
    # required for rootless Podman user namespace mapping
    if ! id "$BAIZE_USER" > /dev/null 2>&1; then
        useradd \
            --create-home \
            --home-dir "$BAIZE_HOME" \
            --shell /usr/sbin/nologin \
            --comment "baize minikube service account" \
            --groups "$CONSUMERS_GROUP" \
            "$BAIZE_USER"
        # Lock the password — no interactive login
        passwd -l "$BAIZE_USER"
        success "User '${BAIZE_USER}' created and locked."
    else
        info "User '${BAIZE_USER}' already exists."
    fi

    # Ensure subuid and subgid ranges exist for rootless Podman
    if ! grep -q "^${BAIZE_USER}:" /etc/subuid 2>/dev/null; then
        # Find a free range starting after any existing entries
        LAST_SUBUID=$(awk -F: '{print $2+$3}' /etc/subuid 2>/dev/null | sort -n | tail -1)
        START=${LAST_SUBUID:-100000}
        echo "${BAIZE_USER}:${START}:65536" >> /etc/subuid
        success "subuid range ${START}:65536 assigned to ${BAIZE_USER}."
    else
        info "subuid entry for '${BAIZE_USER}' already exists."
    fi

    if ! grep -q "^${BAIZE_USER}:" /etc/subgid 2>/dev/null; then
        LAST_SUBGID=$(awk -F: '{print $2+$3}' /etc/subgid 2>/dev/null | sort -n | tail -1)
        START=${LAST_SUBGID:-100000}
        echo "${BAIZE_USER}:${START}:65536" >> /etc/subgid
        success "subgid range ${START}:65536 assigned to ${BAIZE_USER}."
    else
        info "subgid entry for '${BAIZE_USER}' already exists."
    fi
}

# -----------------------------------------------------------------------------
# 5. Consumer selection — config file or debconf, never "all users"
# -----------------------------------------------------------------------------

consumer_selection() {
    info "Selecting consumer users for '${CONSUMERS_GROUP}'..."

    local consumers=""
    local first_admin=""
    local username
    local added=0
    local skipped=0

    # Priority 1: Config file
    if [ -s "$CONSUMERS_CONF" ]; then
        info "Reading consumers from ${CONSUMERS_CONF}..."
        # Read non-empty, non-comment lines
        while IFS= read -r line || [ -n "$line" ]; do
            # Strip inline comments and trim whitespace
            line="${line%%#*}"
            line="$(echo "$line" | xargs)"
            [ -n "$line" ] || continue
            consumers="${consumers}${consumers:+ }${line}"
        done < "$CONSUMERS_CONF"
    fi

    # Priority 2: debconf (interactive only)
    if [ -z "$consumers" ]; then
        if [ -f /usr/share/debconf/confmodule ]; then
            . /usr/share/debconf/confmodule
            db_get baize-kube/consumers || true
            consumers="$(echo "$RET" | xargs)"
        fi
    fi

    # Priority 3: Fail — no fallback to "all users"
    if [ -z "$consumers" ]; then
        if [ -n "${DEBIAN_FRONTEND:-}" ] && [ "$DEBIAN_FRONTEND" = "noninteractive" ]; then
            fail "No ${CONSUMERS_CONF} found and running non-interactively. Create ${CONSUMERS_CONF} with one username per line for unattended installs."
        fi
        fail "No consumers specified. Create ${CONSUMERS_CONF} or re-run interactively."
    fi

    # Validate and add each consumer
    for username in $consumers; do
        # Skip the baize user itself
        if [ "$username" = "$BAIZE_USER" ]; then
            info "Skipping '${BAIZE_USER}' (cluster owner, not a consumer)."
            skipped=$((skipped + 1))
            continue
        fi

        if id "$username" > /dev/null 2>&1; then
            usermod -aG "$CONSUMERS_GROUP" "$username"
            success "Added '${username}' to '${CONSUMERS_GROUP}'."

            # First valid user becomes the initial admin
            if [ -z "$first_admin" ]; then
                first_admin="$username"
            fi

            added=$((added + 1))
        else
            warn "User '${username}' does not exist on this system — skipping."
            skipped=$((skipped + 1))
        fi
    done

    if [ "$added" -eq 0 ] && [ "$skipped" -gt 0 ]; then
        fail "No valid consumer users were added. Check ${CONSUMERS_CONF} or re-run interactively."
    fi

    # Add the first valid user to baize-admins group
    if [ -n "$first_admin" ]; then
        usermod -aG "$ADMINS_GROUP" "$first_admin"
        success "Added '${first_admin}' to '${ADMINS_GROUP}' (initial cluster admin)."
    fi

    info "Consumer selection complete: ${added} added, ${skipped} skipped."
}

# -----------------------------------------------------------------------------
# 6. Download minikube and kubectl binaries
# -----------------------------------------------------------------------------

# Helper for retryable downloads
download_with_retry() {
    local url="$1"
    local output="$2"
    local description="$3"
    local max_retries=3
    local attempt=1

    while [ $attempt -le $max_retries ]; do
        if curl -fsSL --max-time 120 -o "$output" "$url"; then
            return 0
        fi
        warn "Download attempt ${attempt}/${max_retries} failed for ${description}. Retrying in 5s..."
        sleep 5
        attempt=$((attempt + 1))
    done
    return 1
}

download_binaries() {
    info "Downloading minikube ${MINIKUBE_VERSION} (${ARCH})..."

    MINIKUBE_URL="https://github.com/kubernetes/minikube/releases/download/${MINIKUBE_VERSION}/minikube-linux-${ARCH}"
    MINIKUBE_SHA_URL="${MINIKUBE_URL}.sha256"

    # Download binary
    download_with_retry "$MINIKUBE_URL" "${MINIKUBE_BIN}.tmp" "minikube" \
        || fail "Failed to download minikube from ${MINIKUBE_URL}."

    # Download and verify checksum
    info "Verifying minikube checksum..."
    curl -fsSL --max-time 10 -o "${MINIKUBE_BIN}.sha256" "$MINIKUBE_SHA_URL" \
        || fail "Failed to download minikube checksum."

    # Validate checksum file content
    if [ ! -s "${MINIKUBE_BIN}.sha256" ]; then
        rm -f "${MINIKUBE_BIN}.tmp" "${MINIKUBE_BIN}.sha256"
        fail "minikube checksum file is empty or missing."
    fi
    if ! grep -qE '^[a-f0-9]{64}$' "${MINIKUBE_BIN}.sha256"; then
        rm -f "${MINIKUBE_BIN}.tmp" "${MINIKUBE_BIN}.sha256"
        fail "minikube checksum file does not contain a valid SHA256 digest."
    fi

    # Verify binary is reasonably sized (minikube is ~123 MB for arm64)
    MINIKUBE_SIZE=$(stat -c%s "${MINIKUBE_BIN}.tmp" 2>/dev/null || stat -f%z "${MINIKUBE_BIN}.tmp" 2>/dev/null || echo "0")
    if [ "$MINIKUBE_SIZE" -lt 104857600 ]; then  # 100 MB minimum
        rm -f "${MINIKUBE_BIN}.tmp"
        fail "minikube binary is too small (${MINIKUBE_SIZE} bytes). Download may be incomplete."
    fi

    # The .sha256 file from GitHub releases contains just the hex digest (e.g., "a0b8a1eb...")
    # awk '{print $1}' extracts it regardless of whether there's a trailing filename
    EXPECTED=$(awk '{print $1}' "${MINIKUBE_BIN}.sha256")
    ACTUAL=$(sha256sum "${MINIKUBE_BIN}.tmp" | awk '{print $1}')

    # SHA256 digests are lowercase by convention; comparison is case-sensitive
    if [ "$EXPECTED" != "$ACTUAL" ]; then
        rm -f "${MINIKUBE_BIN}.tmp" "${MINIKUBE_BIN}.sha256"
        fail "minikube checksum verification FAILED. Expected: ${EXPECTED}, Got: ${ACTUAL}"
    fi

    # Defense-in-depth: also verify against hardcoded expected hash
    if [ "$EXPECTED" != "$MINIKUBE_SHA256" ]; then
        warn "minikube checksum does not match hardcoded expected hash (version may have changed)."
        warn "Expected: ${MINIKUBE_SHA256}"
        warn "Got:      ${EXPECTED}"
        # Non-fatal: the downloaded checksum already matched the binary
    fi

    mv "${MINIKUBE_BIN}.tmp" "$MINIKUBE_BIN"
    chmod +x "$MINIKUBE_BIN"
    rm -f "${MINIKUBE_BIN}.sha256"

    success "minikube ${MINIKUBE_VERSION} installed and verified at ${MINIKUBE_BIN}."

    # kubectl — same pattern, using pinned version
    info "Downloading kubectl ${KUBECTL_VERSION} (${ARCH})..."

    KUBECTL_URL="https://dl.k8s.io/release/${KUBECTL_VERSION}/bin/linux/${ARCH}/kubectl"
    KUBECTL_SHA_URL="${KUBECTL_URL}.sha256"

    download_with_retry "$KUBECTL_URL" "${KUBECTL_BIN}.tmp" "kubectl" \
        || fail "Failed to download kubectl from ${KUBECTL_URL}."

    info "Verifying kubectl checksum..."
    curl -fsSL --max-time 10 -o "${KUBECTL_BIN}.sha256" "$KUBECTL_SHA_URL" \
        || fail "Failed to download kubectl checksum."

    EXPECTED=$(awk '{print $1}' "${KUBECTL_BIN}.sha256")
    ACTUAL=$(sha256sum "${KUBECTL_BIN}.tmp" | awk '{print $1}')

    if [ "$EXPECTED" != "$ACTUAL" ]; then
        rm -f "${KUBECTL_BIN}.tmp" "${KUBECTL_BIN}.sha256"
        fail "kubectl checksum verification FAILED. Expected: ${EXPECTED}, Got: ${ACTUAL}"
    fi

    mv "${KUBECTL_BIN}.tmp" "$KUBECTL_BIN"
    chmod +x "$KUBECTL_BIN"
    rm -f "${KUBECTL_BIN}.sha256"

    # Note: Kubernetes does not publish GPG signatures for kubectl binaries.
    # SHA256 checksum verification (above) is the primary integrity check.
    # For defense-in-depth, the checksum file itself is served over HTTPS from dl.k8s.io.

    success "kubectl ${KUBECTL_VERSION} installed and verified at ${KUBECTL_BIN}."
}

# -----------------------------------------------------------------------------
# 7. Enable systemd lingering for baize
# -----------------------------------------------------------------------------

enable_lingering() {
    info "Enabling systemd lingering for '${BAIZE_USER}'..."
    loginctl enable-linger "$BAIZE_USER"
    success "Lingering enabled — baize user services will start at boot."
}

# -----------------------------------------------------------------------------
# 7b. Install management scripts
# -----------------------------------------------------------------------------

install_management_scripts() {
    info "Ensuring management scripts are executable..."

    local scripts="baize-kube-add-consumer baize-kube-remove-consumer baize-kube-list-consumers baize-kube-update-kubeconfig"
    local script

    for script in $scripts; do
        if [ -f "/usr/local/bin/${script}" ]; then
            chmod 755 "/usr/local/bin/${script}"
            chown root:root "/usr/local/bin/${script}"
            success "Verified ${script}."
        else
            warn "Management script '${script}' not found at /usr/local/bin/${script} — skipping."
        fi
    done
}

# -----------------------------------------------------------------------------
# 8. Configure minikube for baize user
# -----------------------------------------------------------------------------

configure_minikube() {
    info "Configuring minikube for user '${BAIZE_USER}'..."

    runuser -l "$BAIZE_USER" -s /bin/bash -c "
        export HOME=${BAIZE_HOME}
        export XDG_RUNTIME_DIR=/run/user/\$(id -u)
        minikube config set driver podman
        minikube config set rootless true
        minikube config set container-runtime containerd
    " || fail "Failed to configure minikube for ${BAIZE_USER}."

    success "minikube configured for '${BAIZE_USER}'."
}

# -----------------------------------------------------------------------------
# 9. Install systemd user service for minikube
# -----------------------------------------------------------------------------

install_service() {
    info "Installing minikube systemd user service for '${BAIZE_USER}'..."

    mkdir -p "$MINIKUBE_SERVICE_DIR"
    chown -R "${BAIZE_USER}:${BAIZE_GROUP}" "${BAIZE_HOME}/.config"

    cat > "$MINIKUBE_SERVICE" <<EOF
[Unit]
Description=minikube Kubernetes cluster
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
Environment=HOME=${BAIZE_HOME}
Environment=MINIKUBE_ROOTLESS=true
ExecStart=${MINIKUBE_BIN} start --driver=podman --no-vtx-check
ExecStop=${MINIKUBE_BIN} stop
TimeoutStartSec=300

[Install]
WantedBy=default.target
EOF

    chown "${BAIZE_USER}:${BAIZE_GROUP}" "$MINIKUBE_SERVICE"

    # Enable the service as the baize user
    runuser -l "$BAIZE_USER" -s /bin/bash -c "
        export HOME=${BAIZE_HOME}
        export XDG_RUNTIME_DIR=/run/user/\$(id -u)
        systemctl --user daemon-reload
        systemctl --user enable minikube.service
    " || fail "Failed to enable minikube user service."

    success "minikube user service installed and enabled."
}

# -----------------------------------------------------------------------------
# 10. Start minikube cluster and export kubeconfig
# -----------------------------------------------------------------------------

start_cluster() {
    info "Starting minikube cluster as '${BAIZE_USER}' (this may take several minutes)..."

    runuser -l "$BAIZE_USER" -s /bin/bash -c "
        export HOME=${BAIZE_HOME}
        export XDG_RUNTIME_DIR=/run/user/\$(id -u)
        export MINIKUBE_ROOTLESS=true
        ${MINIKUBE_BIN} start --driver=podman --no-vtx-check
    " || fail "minikube failed to start. Check: sudo -u baize minikube logs"

    success "minikube cluster started."

    # Verify the API server is responding before proceeding
    info "Verifying cluster is healthy..."
    for _ in $(seq 1 30); do
        if runuser -l "$BAIZE_USER" -s /bin/bash -c "
            export HOME=${BAIZE_HOME}
            export XDG_RUNTIME_DIR=/run/user/\$(id -u)
            export MINIKUBE_ROOTLESS=true
            ${KUBECTL_BIN} get nodes --request-timeout=5s 2>/dev/null
        "; then
            success "Cluster API server is responding."
            return 0
        fi
        sleep 2
    done
    fail "Cluster started but API server did not become healthy within 60 seconds."
}

# -----------------------------------------------------------------------------
# 11. Provision admin kubeconfig for baize-admins group
# -----------------------------------------------------------------------------

provision_kubeconfig() {
    info "Provisioning admin kubeconfig for '${ADMINS_GROUP}'..."

    mkdir -p /etc/baize-kube
    chown "root:${ADMINS_GROUP}" /etc/baize-kube
    chmod 750 /etc/baize-kube

    runuser -l "$BAIZE_USER" -s /bin/bash -c "
        export HOME=${BAIZE_HOME}
        export XDG_RUNTIME_DIR=/run/user/\$(id -u)
        export MINIKUBE_ROOTLESS=true
        ${MINIKUBE_BIN} kubectl -- config view --flatten > ${ADMIN_KUBECONFIG}
    " || fail "Failed to export admin kubeconfig."

    chown "root:${ADMINS_GROUP}" "$ADMIN_KUBECONFIG"
    chmod 640 "$ADMIN_KUBECONFIG"

    success "Admin kubeconfig written to ${ADMIN_KUBECONFIG} (group: ${ADMINS_GROUP})."

    # Consumer kubeconfigs are NOT created here.
    # They are created on-demand by baize-kube-add-consumer.
    info "Consumer kubeconfigs are created on-demand with: sudo baize-kube-add-consumer <username>"
}

# -----------------------------------------------------------------------------
# 12. Shell profile hint for admins
# -----------------------------------------------------------------------------

install_profile_hint() {
    PROFILE_SNIPPET="/etc/profile.d/baize-kube.sh"
    cat > "$PROFILE_SNIPPET" <<'PROFILEEOF'
# baize-kube: set KUBECONFIG for cluster admins
# Admins get full access via the admin kubeconfig.
# Consumers use kubectl's default location (~/.kube/config).
if id -nG "$USER" 2>/dev/null | grep -qw "baize-admins"; then
    export KUBECONFIG=/etc/baize-kube/admin-kubeconfig
fi
PROFILEEOF
    chmod 644 "$PROFILE_SNIPPET"
    success "Shell profile snippet installed at ${PROFILE_SNIPPET}."
    success "KUBECONFIG will be auto-set for members of '${ADMINS_GROUP}' on next login."
    info "Consumers use kubectl's default location (~/.kube/config) — no env var needed."
}

# -----------------------------------------------------------------------------
# Main
# -----------------------------------------------------------------------------

# Only run full installation on 'configure'
ACTION="${1:-}"
if [ "$ACTION" != "configure" ] && [ -n "$ACTION" ]; then
    # For abort-upgrade, abort-remove, etc. — nothing to do
    exit 0
fi

require_root
check_network
check_and_patch_cgroup
configure_cgroup_delegation
provision_user
consumer_selection
download_binaries
install_management_scripts
enable_lingering
configure_minikube
install_service
start_cluster
provision_kubeconfig
install_profile_hint

echo ""
echo "╔══════════════════════════════════════════════════════════════╗"
echo "║  baize-kube installation complete                           ║"
echo "║                                                             ║"
echo "║  Cluster owner:  baize  (locked, no interactive login)     ║"
echo "║  Admins:         members of 'baize-admins' group           ║"
echo "║  Consumers:      members of 'baize-consumers' group       ║"
echo "║  Admin config:   /etc/baize-kube/admin-kubeconfig          ║"
echo "║                                                             ║"
echo "║  Admins: log out and back in, then run:                    ║"
echo "║    kubectl get nodes                                        ║"
echo "║                                                             ║"
echo "║  To provision a consumer:                                   ║"
echo "║    sudo baize-kube-add-consumer <username>                  ║"
echo "║                                                             ║"
echo "║  To list provisioned consumers:                             ║"
echo "║    baize-kube-list-consumers                                ║"
echo "║                                                             ║"
echo "║  To reconfigure minikube:                                   ║"
echo "║    sudo -u baize minikube <command>                        ║"
echo "║                                                             ║"
echo "║  To check service status:                                   ║"
echo "║    sudo -u baize systemctl --user status minikube          ║"
echo "╚══════════════════════════════════════════════════════════════╝"
